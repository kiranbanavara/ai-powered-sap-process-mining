# ---- LLM provider credentials (pick the one(s) you use) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ---- S/4HANA OData (cloud or on-prem API Management) ----
S4_BASE_URL=https://my-s4-system.example.com
S4_USER=
S4_PASSWORD=
# OR use OAuth client credentials instead of basic auth:
S4_OAUTH_TOKEN_URL=
S4_OAUTH_CLIENT_ID=
S4_OAUTH_CLIENT_SECRET=

# ---- ECC (SAP NetWeaver RFC) ----
ECC_ASHOST=
ECC_SYSNR=00
ECC_CLIENT=100
ECC_USER=
ECC_PASSWORD=

# ---- Optional: HANA direct ----
HANA_HOST=
HANA_PORT=30015
HANA_USER=
HANA_PASSWORD=
